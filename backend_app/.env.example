# DELPHI inference backend — environment template.
# Copy to `.env` and fill in real values. `.env` is gitignored; never commit secrets.

# ── Redis cache backend (optional). Set ONE of the two blocks.
#    When set, the Store reads the Stage-2 cache from Redis (stateless serving).
#    When unset, it falls back to local files under DELPHI_CACHE_DIR.
#    (1) Upstash REST — serverless, only needs `requests` (already a dep):
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
#    (2) Standard Redis — needs `redis-py`:
# REDIS_URL=redis://localhost:6379

# ── Stage-1 source (only used by recache in full/GPU mode)
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_KEY=

# ── Paths (optional overrides; defaults are relative to backend_app/)
# DELPHI_CONFIG=config/delphi_config.yaml
# DELPHI_TBOX=config/delphi_tbox_v0.2.ttl
# DELPHI_CACHE_DIR=cache
# DELPHI_DEV_DATA=../backend_dev/data
