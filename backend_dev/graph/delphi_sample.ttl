dlp: a owl:Ontology ;
    rdfs:label "DELPHI observation ontology"@en ;
    rdfs:comment "관측가능 실재 + 관측 사실만. 상태·가설·증거·파라미터는 추론엔진 레이어(온톨로지 밖)."@ko ;
    owl:versionInfo "0.2" .

dlp:AerialIMINT rdfs:label "항공영상"@ko ;
    rdfs:subClassOf dlp:CollectionAsset .

dlp:LaunchPad rdfs:label "발사대"@ko ;
    rdfs:subClassOf dlp:Facility .

dlp:NuclearTestSite rdfs:label "핵실험장"@ko ;
    rdfs:subClassOf dlp:Facility .

dlp:OxidizerVehicle rdfs:label "산화제차량"@ko ;
    rdfs:subClassOf dlp:MobileObject .

dlp:SubmarineBase rdfs:label "잠수함기지"@ko ;
    rdfs:subClassOf dlp:Facility .

dlp:TEL rdfs:label "이동식발사대"@ko ;
    rdfs:subClassOf dlp:Transporter .

dlp:atLocation a owl:ObjectProperty ;
    rdfs:domain dlp:Observation ;
    rdfs:range dlp:SpatialRegion .

dlp:collectedAt a owl:DatatypeProperty ;
    rdfs:domain dlp:Observation ;
    rdfs:range xsd:dateTime .

dlp:collectedBy a owl:ObjectProperty ;
    rdfs:domain dlp:Observation ;
    rdfs:range dlp:CollectionAsset .

dlp:count a owl:DatatypeProperty ;
    rdfs:range xsd:integer .

dlp:derivedFrom a owl:DatatypeProperty ;
    rdfs:domain dlp:Observation ;
    rdfs:range xsd:string .

dlp:locatedAt a owl:ObjectProperty ;
    rdfs:domain dlp:Facility ;
    rdfs:range dlp:NamedLocation .

dlp:mgrs a owl:DatatypeProperty ;
    rdfs:domain dlp:MGRSCell ;
    rdfs:range xsd:string .

dlp:observedActivity a owl:ObjectProperty ;
    rdfs:domain dlp:Observation ;
    rdfs:range dlp:Activity .

dlp:observedObject a owl:ObjectProperty ;
    rdfs:domain dlp:Observation .

dlp:observedSignal a owl:ObjectProperty ;
    rdfs:domain dlp:Observation ;
    rdfs:range dlp:Emission .

dlp:platform a owl:DatatypeProperty ;
    rdfs:domain dlp:CollectionAsset ;
    rdfs:range xsd:string .

dlp:polarity a owl:DatatypeProperty ;
    rdfs:domain dlp:Observation ;
    rdfs:range xsd:string .

dlp:reliabilityGrade a owl:DatatypeProperty ;
    rdfs:domain dlp:Observation ;
    rdfs:range xsd:integer .

dlp:spuqUncertainty a owl:DatatypeProperty ;
    rdfs:range xsd:double .

dlp:withinCell a owl:ObjectProperty ;
    rdfs:domain dlp:NamedLocation ;
    rdfs:range dlp:MGRSCell .

