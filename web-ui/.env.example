# Copy to `.env.local` and fill in. `.env.local` is gitignored.
# These moved here from backend/.env — the frontend now talks to Supabase directly.

# Supabase (Delphi project) — public, browser-safe keys.
NEXT_PUBLIC_SUPABASE_URL=https://jahosulejxmqjyjkvhno.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key — SERVER ONLY, never exposed to the browser.
# Used by the Next.js API route src/app/api/events to read `observation`.
SUPABASE_SERVICE_ROLE_KEY=

# FastAPI backend base URL (legacy — events now come from Next.js, not FastAPI).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
